# Prode Mundial — variables de entorno.
# Copiar a `.env.local` y completar. NUNCA commitear `.env.local`.

# ── Supabase ──────────────────────────────────────────────
# Públicas (van al bundle del cliente):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo server-side, NUNCA exponer al cliente:
SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis (solo server-side) ──────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── API-Football (solo server-side) ───────────────────────
API_FOOTBALL_KEY=

# ── worldcup26.ir (solo server-side) ──────────────────────
# Endpoint JSON de los partidos. Solo lo usa el seed (npm run db:seed). La URL de
# equipos (banderas) se deriva sola: /get/games → /get/teams.
WORLDCUP_FIXTURE_URL=https://worldcup26.ir/get/games

# ── Cron (solo server-side) ───────────────────────────────
# Protege los endpoints de cron: Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=

# ── Web Push / VAPID (opcional — habilita push notifications) ──
# Generar con `npm run gen:vapid`. Una sola vez por entorno (rotarlas
# invalida todas las suscripciones). Si faltan, el push queda deshabilitado.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BF7Aj8Tudcz2RXQjHzS54bFYb-khKbCaeHw6lc1YgAKUMuZ6wdL3kUVh5HICg2fygIsV3dyWf9fYImUa0J4vD54
VAPID_PRIVATE_KEY=mYImnula6LCiRaTjOC3lUQTvzGX5PkslR4Hnl-SqCCQ
